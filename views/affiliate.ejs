<%- include('partials/header', { title: 'Affiliate Program', pageCss: 'dashboard' }) %>

<div class="dashboard-layout">
    <div class="sidebar-overlay" id="sidebarOverlay"></div>
    <%- include('partials/sidebar') %>

    <main class="main-content">
        <section class="action-bar">
            <div class="left-actions">
                <button class="icon-btn mobile-menu-btn" id="sidebarToggle">
                    <i class="fa-solid fa-bars"></i>
                </button>
                <h1 style="font-size: 1.5rem; margin: 0;">Referral Center</h1>
            </div>
        </section>

        <div class="affiliate-shell">
            <section class="affiliate-hero">
                <div>
                    <span class="affiliate-badge">Referral Growth</span>
                    <h2>Bagikan halaman referral Anda dan tarik pengguna baru lewat landing page yang punya identitas jelas.</h2>
                    <p>Link referral sekarang diarahkan ke halaman khusus yang menampilkan username Anda, kode referral, dan banner otomatis dari canvas agar lebih meyakinkan saat dibagikan.</p>
                </div>
                <div class="affiliate-stats">
                    <div class="stat-card">
                        <small>Total referral</small>
                        <strong><%= referrals.length %></strong>
                    </div>
                    <div class="stat-card">
                        <small>Wallet balance</small>
                        <strong>$<%= user.walletBalance.toFixed(2) %></strong>
                    </div>
                    <div class="stat-card">
                        <small>Bonus storage</small>
                        <strong><%= (user.storageBonus / 1024 / 1024).toFixed(0) %> MB</strong>
                    </div>
                </div>
            </section>

            <div class="affiliate-grid">
                <section class="affiliate-card share-card">
                    <h3>Landing page referral Anda</h3>
                    <p>Bagikan link ini agar calon pengguna masuk ke halaman referral milik Anda, bukan langsung ke register kosong.</p>
                    <div class="link-box" id="landingLink"><%= referralLandingUrl %></div>
                    <div class="share-actions">
                        <button class="btn primary-btn" id="copyLandingBtn">
                            <i class="fa-solid fa-copy"></i> Copy Link
                        </button>
                        <a href="<%= referralLandingUrl %>" target="_blank" class="btn secondary-btn">
                            <i class="fa-solid fa-up-right-from-square"></i> Buka Landing Page
                        </a>
                    </div>

                    <div class="banner-preview">
                        <img src="<%= referralBannerUrl %>" alt="Referral banner">
                    </div>

                    <div class="share-actions">
                        <button class="btn secondary-btn" id="copyBannerBtn">
                            <i class="fa-solid fa-image"></i> Copy Banner URL
                        </button>
                        <a href="<%= referralBannerUrl %>" target="_blank" class="btn secondary-btn">
                            <i class="fa-solid fa-download"></i> Lihat Banner
                        </a>
                    </div>
                </section>

                <section class="affiliate-card">
                    <h3>Kode referral aktif</h3>
                    <p>Pendaftaran baru yang masuk dari halaman referral Anda akan tetap memakai kode ini saat registrasi.</p>
                    <div class="ref-code-box">
                        <strong id="refCodeValue"><%= user.referralCode %></strong>
                        <button class="icon-btn" id="copyCodeBtn"><i class="fa-solid fa-copy"></i></button>
                    </div>
                    <div class="note-box">
                        <i class="fa-solid fa-sparkles"></i>
                        <span>Bonus default saat referral sukses: +50 MB untuk referrer dan pengguna baru.</span>
                    </div>
                </section>
            </div>

            <section class="affiliate-card referrals-card">
                <div class="section-head">
                    <div>
                        <h3>Pengguna yang bergabung lewat Anda</h3>
                        <p>Daftar referral terbaru dan status paket mereka.</p>
                    </div>
                </div>

                <% if (referrals.length === 0) { %>
                    <div class="empty-state affiliate-empty">
                        <i class="fa-solid fa-users-slash"></i>
                        <p>Belum ada referral masuk. Coba bagikan landing page dan banner di sosial media atau chat.</p>
                    </div>
                <% } else { %>
                    <div class="referral-list">
                        <% referrals.forEach(ref => { %>
                            <article class="referral-row">
                                <div>
                                    <strong><%= ref.username %></strong>
                                    <small>Bergabung <%= new Date(ref.createdAt).toLocaleDateString('id-ID') %></small>
                                </div>
                                <div class="referral-badges">
                                    <% if (ref.isVerified) { %>
                                        <span class="badge verified">Verified</span>
                                    <% } %>
                                    <span class="badge <%= ref.plan === 'pro' ? 'pro' : 'free' %>"><%= ref.plan.toUpperCase() %></span>
                                </div>
                            </article>
                        <% }) %>
                    </div>
                <% } %>
            </section>
        </div>
    </main>
</div>

<style>
    .affiliate-shell { padding: 1.5rem; max-width: 1220px; margin: 0 auto; }
    .affiliate-hero {
        display: grid;
        grid-template-columns: minmax(0, 1.45fr) minmax(320px, 0.85fr);
        gap: 1.5rem;
        padding: 1.8rem;
        border-radius: 28px;
        background:
            radial-gradient(circle at top right, rgba(249,115,22,0.18), transparent 24%),
            linear-gradient(135deg, rgba(12, 74, 110, 0.96), rgba(37, 99, 235, 0.92));
        color: #fff;
        margin-bottom: 1.5rem;
        border: 1px solid rgba(255,255,255,0.16);
    }
    .affiliate-badge {
        display: inline-flex;
        padding: 0.35rem 0.72rem;
        border-radius: 999px;
        background: rgba(255,255,255,0.14);
        font-size: 0.76rem;
        font-weight: 800;
        letter-spacing: 0.05em;
        text-transform: uppercase;
    }
    .affiliate-hero h2 { margin: 0.85rem 0 0.75rem; font-size: clamp(2rem, 3vw, 2.6rem); line-height: 1.12; }
    .affiliate-hero p { margin: 0; color: rgba(255,255,255,0.78); line-height: 1.75; }
    .affiliate-stats { display: grid; gap: 1rem; }
    .stat-card {
        padding: 1rem 1.15rem;
        border-radius: 22px;
        background: rgba(255,255,255,0.12);
        border: 1px solid rgba(255,255,255,0.16);
    }
    .stat-card small { display: block; color: rgba(255,255,255,0.72); margin-bottom: 0.35rem; }
    .stat-card strong { font-size: 1.65rem; }
    .affiliate-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.35fr) minmax(320px, 0.85fr);
        gap: 1.5rem;
        margin-bottom: 1.5rem;
    }
    .affiliate-card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 24px;
        padding: 1.5rem;
        box-shadow: 0 20px 40px rgba(15, 23, 42, 0.06);
    }
    .affiliate-card h3 { margin-top: 0; margin-bottom: 0.4rem; }
    .affiliate-card p { color: var(--muted-text); line-height: 1.65; }
    .link-box, .ref-code-box {
        background: var(--bg-secondary);
        border: 1px solid var(--border);
        border-radius: 18px;
        padding: 1rem 1.1rem;
        margin-top: 1rem;
    }
    .link-box {
        font-family: monospace;
        word-break: break-all;
        font-size: 0.95rem;
    }
    .ref-code-box {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
    }
    .ref-code-box strong {
        font-size: 1.8rem;
        letter-spacing: 0.12em;
    }
    .share-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-top: 1rem;
    }
    .banner-preview {
        margin-top: 1.2rem;
        overflow: hidden;
        border-radius: 22px;
        border: 1px solid var(--border);
        background: var(--bg-secondary);
    }
    .banner-preview img { width: 100%; display: block; }
    .note-box {
        margin-top: 1rem;
        display: flex;
        gap: 0.75rem;
        align-items: flex-start;
        padding: 1rem;
        border-radius: 18px;
        background: rgba(37,99,235,0.08);
        border: 1px solid rgba(37,99,235,0.14);
        color: var(--muted-text);
    }
    .referrals-card { margin-bottom: 2rem; }
    .section-head h3 { margin: 0; }
    .section-head p { margin: 0.35rem 0 0; }
    .referral-list { display: grid; gap: 0.9rem; }
    .referral-row {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: center;
        padding: 1rem 1.1rem;
        border-radius: 18px;
        background: var(--bg-secondary);
        border: 1px solid var(--border);
    }
    .referral-row strong { display: block; }
    .referral-row small { color: var(--muted-text); }
    .referral-badges { display: flex; gap: 0.55rem; flex-wrap: wrap; }
    .badge {
        display: inline-flex;
        padding: 0.35rem 0.7rem;
        border-radius: 999px;
        font-size: 0.72rem;
        font-weight: 800;
        text-transform: uppercase;
    }
    .badge.verified { background: rgba(59,130,246,0.12); color: #1d4ed8; }
    .badge.pro { background: rgba(245,158,11,0.14); color: #b45309; }
    .badge.free { background: rgba(15,23,42,0.08); color: var(--muted-text); }
    .affiliate-empty { min-height: 220px; }
    @media (max-width: 980px) {
        .affiliate-hero, .affiliate-grid { grid-template-columns: 1fr; }
    }
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const sidebar = document.getElementById('mainSidebar');
    const sidebarToggle = document.getElementById('sidebarToggle');
    const sidebarOverlay = document.getElementById('sidebarOverlay');
    const closeSidebarBtn = document.getElementById('closeSidebarBtn');

    function toggleSidebar() {
        if (sidebar) sidebar.classList.toggle('active');
        if (sidebarOverlay) sidebarOverlay.classList.toggle('active');
    }

    if (sidebarToggle) sidebarToggle.addEventListener('click', toggleSidebar);
    if (closeSidebarBtn) closeSidebarBtn.addEventListener('click', toggleSidebar);
    if (sidebarOverlay) sidebarOverlay.addEventListener('click', toggleSidebar);

    document.getElementById('copyLandingBtn')?.addEventListener('click', async () => {
        await navigator.clipboard.writeText(document.getElementById('landingLink').innerText);
        showToast('Landing link copied.', 'success');
    });

    document.getElementById('copyBannerBtn')?.addEventListener('click', async () => {
        await navigator.clipboard.writeText(`${window.location.origin}<%= referralBannerUrl %>`);
        showToast('Banner URL copied.', 'success');
    });

    document.getElementById('copyCodeBtn')?.addEventListener('click', async () => {
        await navigator.clipboard.writeText(document.getElementById('refCodeValue').innerText);
        showToast('Referral code copied.', 'success');
    });
});
</script>

<%- include('partials/footer') %>
