<%- include('partials/header', { title: `Referral ${referrer.username}`, pageCss: 'auth' }) %>

<main class="referral-landing">
    <section class="referral-hero-card">
        <div class="referral-copy">
            <span class="referral-pill">Referral Invite</span>
            <h1>Bergabung lewat <span>@<%= referrer.username %></span> dan mulai simpan file dengan workspace yang lebih rapi.</h1>
            <p><%= referrer.publicBio || 'Dapat bonus storage saat daftar lewat referral ini, lalu lanjut pakai dashboard upload, share, dan workspace yang sudah ditingkatkan.' %></p>

            <div class="referral-highlights">
                <div class="highlight-item">
                    <small>Kode referral</small>
                    <strong><%= referrer.referralCode %></strong>
                </div>
                <div class="highlight-item">
                    <small>Total referral</small>
                    <strong><%= referrer.referralCount || 0 %></strong>
                </div>
                <div class="highlight-item">
                    <small>Bonus awal</small>
                    <strong>+50 MB</strong>
                </div>
            </div>

            <div class="referral-actions">
                <a href="<%= referralRegisterUrl %>" class="btn primary-btn">
                    <i class="fa-solid fa-user-plus"></i> Daftar Sekarang
                </a>
                <button class="btn secondary-btn" id="copyReferralPageBtn">
                    <i class="fa-solid fa-copy"></i> Copy Link Halaman
                </button>
            </div>
        </div>

        <div class="referral-visual">
            <img src="<%= referralBannerUrl %>" alt="Referral banner for <%= referrer.username %>">
        </div>
    </section>
</main>

<style>
    .referral-landing {
        max-width: 1220px;
        margin: 0 auto;
        padding: 2rem 1.25rem 3rem;
    }
    .referral-hero-card {
        display: grid;
        grid-template-columns: minmax(0, 1.1fr) minmax(360px, 0.9fr);
        gap: 1.6rem;
        padding: 1.8rem;
        border-radius: 32px;
        background:
            radial-gradient(circle at top right, rgba(249,115,22,0.18), transparent 26%),
            linear-gradient(135deg, rgba(15,23,42,0.96), rgba(37,99,235,0.92));
        color: #fff;
        border: 1px solid rgba(255,255,255,0.16);
        box-shadow: 0 30px 60px rgba(15, 23, 42, 0.18);
    }
    .referral-pill {
        display: inline-flex;
        padding: 0.35rem 0.75rem;
        border-radius: 999px;
        background: rgba(255,255,255,0.14);
        font-size: 0.76rem;
        font-weight: 800;
        letter-spacing: 0.05em;
        text-transform: uppercase;
    }
    .referral-copy h1 {
        margin: 0.95rem 0 0.85rem;
        font-size: clamp(2.1rem, 4vw, 3.2rem);
        line-height: 1.08;
    }
    .referral-copy h1 span { color: #fde68a; }
    .referral-copy p {
        margin: 0;
        color: rgba(255,255,255,0.78);
        line-height: 1.8;
        max-width: 720px;
    }
    .referral-highlights {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
        gap: 1rem;
        margin-top: 1.4rem;
    }
    .highlight-item {
        padding: 1rem 1.1rem;
        border-radius: 20px;
        background: rgba(255,255,255,0.10);
        border: 1px solid rgba(255,255,255,0.16);
    }
    .highlight-item small {
        display: block;
        color: rgba(255,255,255,0.72);
        margin-bottom: 0.3rem;
    }
    .highlight-item strong { font-size: 1.35rem; }
    .referral-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.85rem;
        margin-top: 1.4rem;
    }
    .referral-visual {
        border-radius: 26px;
        overflow: hidden;
        border: 1px solid rgba(255,255,255,0.16);
        background: rgba(255,255,255,0.08);
        align-self: center;
    }
    .referral-visual img { width: 100%; display: block; }
    @media (max-width: 980px) {
        .referral-hero-card { grid-template-columns: 1fr; }
    }
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
    document.getElementById('copyReferralPageBtn')?.addEventListener('click', async () => {
        await navigator.clipboard.writeText(window.location.href);
        showToast('Referral page copied.', 'success');
    });
});
</script>

<%- include('partials/footer') %>
