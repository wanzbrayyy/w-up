<%- include('partials/header', { title: 'Account Settings', pageCss: 'dashboard' }) %>

<script src="https://cdn.jsdelivr.net/npm/@simplewebauthn/browser/dist/bundle/index.umd.min.js"></script>

<div class="dashboard-layout">
    <div class="sidebar-overlay" id="sidebarOverlay"></div>
    <%- include('partials/sidebar') %>

    <main class="main-content">
        <section class="action-bar">
            <div class="left-actions">
                <button class="icon-btn mobile-menu-btn" id="sidebarToggle">
                    <i class="fa-solid fa-bars"></i>
                </button>
                <h1 style="font-size: 1.5rem; margin: 0;">Account Settings</h1>
            </div>
        </section>

        <div class="profile-container">
            <section class="profile-hero">
                <div class="profile-hero-copy">
                    <span class="profile-hero-badge">Workspace Identity</span>
                    <div class="quote-bubbles">
                        <div class="quote-bubble incoming">
                            <span class="quote-author">@<%= user.username %></span>
                            <p>Profil sekarang lebih rapi, lebih gampang dibagikan, dan kontrol akun dikumpulkan di satu tempat.</p>
                        </div>
                        <div class="quote-bubble outgoing">
                            <p>Referral, keamanan, branding, dan billing sekarang terasa seperti panel chat status yang lebih hidup.</p>
                        </div>
                    </div>
                    <div class="profile-hero-stats">
                        <div class="hero-stat">
                            <small>Plan</small>
                            <strong><%= user.plan.toUpperCase() %></strong>
                        </div>
                        <div class="hero-stat">
                            <small>Referral</small>
                            <strong><%= user.referralCount || 0 %></strong>
                        </div>
                        <div class="hero-stat">
                            <small>Storage bonus</small>
                            <strong><%= (user.storageBonus / 1024 / 1024).toFixed(0) %> MB</strong>
                        </div>
                    </div>
                </div>
                <div class="profile-hero-panel">
                    <div class="hero-panel-profile">
                        <% if (user.profilePhotoUrl) { %>
                            <img src="<%= user.profilePhotoUrl %>" alt="Profile photo">
                        <% } else { %>
                            <div class="hero-panel-fallback"><%= user.username.slice(0, 1).toUpperCase() %></div>
                        <% } %>
                        <div>
                            <small>Public page</small>
                            <strong><%= user.isPublicProfile ? 'Active' : 'Hidden' %></strong>
                            <span><%= user.isPublicProfile ? (user.publicTitle || `/u/${user.username}`) : 'Aktifkan public profile untuk membagikan halaman Anda.' %></span>
                        </div>
                    </div>
                    <a href="/billing" class="btn primary-btn" style="width:100%; justify-content:center;">
                        <i class="fa-solid fa-credit-card"></i> Billing & Payment
                    </a>
                </div>
            </section>

            <div class="settings-grid">
                
                <section class="settings-card">
                    <div class="card-header">
                        <h3><i class="fa-solid fa-user-circle"></i> Public Profile</h3>
                    </div>
                    <div class="card-body">
                        <div class="form-group">
                            <label>Username</label>
                            <input type="text" class="full-input" value="<%= user.username %>" readonly disabled>
                        </div>
                        <div class="form-group">
                            <label>Email</label>
                            <input type="email" id="accountEmail" class="full-input" placeholder="you@example.com" value="<%= user.email || '' %>">
                        </div>
                        <div class="form-group">
                            <label>Public Title</label>
                            <input type="text" id="publicTitle" class="full-input" placeholder="My Public Page" value="<%= user.publicTitle || '' %>">
                        </div>
                        <div class="form-group">
                            <label>Bio</label>
                            <textarea id="publicBio" class="full-input" rows="3" placeholder="Tell something about yourself..."><%= user.publicBio || '' %></textarea>
                        </div>
                        <div class="form-group">
                            <label>Profile Photo</label>
                            <input type="file" id="profilePhotoFile" class="full-input" accept="image/*">
                            <small class="field-help">Foto ini dipakai di public page, referral banner, dan panel profil.</small>
                            <div class="branding-preview" id="profilePhotoPreview">
                                <% if (user.profilePhotoUrl) { %>
                                    <img src="<%= user.profilePhotoUrl %>" alt="Profile photo preview">
                                <% } else { %>
                                    <div class="branding-preview-empty"><i class="fa-solid fa-user-circle"></i><span>No profile photo selected</span></div>
                                <% } %>
                            </div>
                        </div>
                        <div class="form-group">
                            <label>Public Cover / Decoration</label>
                            <input type="file" id="publicCoverFile" class="full-input" accept="image/*">
                            <small class="field-help">Gambar ini dipakai sebagai dekorasi header public profile.</small>
                            <div class="branding-preview" id="publicCoverPreview">
                                <% if (user.publicCoverUrl) { %>
                                    <img src="<%= user.publicCoverUrl %>" alt="Public cover preview">
                                <% } else { %>
                                    <div class="branding-preview-empty"><i class="fa-solid fa-panorama"></i><span>No cover selected</span></div>
                                <% } %>
                            </div>
                        </div>
                        <div class="form-group">
                            <label>Public Theme Color</label>
                            <input type="color" id="publicThemeColor" class="full-input" value="<%= user.publicThemeColor || '#2563eb' %>" style="padding: 5px; height: 40px;">
                        </div>
                        <div class="form-row">
                            <label class="toggle-switch">
                                <input type="checkbox" id="publicProfileToggle" <%= user.isPublicProfile ? 'checked' : '' %>>
                                <span class="slider"></span>
                                <span class="label-text">Enable Public Profile</span>
                            </label>
                        </div>
                        <div class="form-actions">
                            <a href="/u/<%= user.username %>" target="_blank" class="btn secondary-btn">View Profile</a>
                            <button id="saveProfileBtn" class="btn primary-btn">Save Changes</button>
                        </div>
                    </div>
                </section>

                <section class="settings-card">
                    <div class="card-header">
                        <h3><i class="fa-solid fa-palette"></i> Page Branding (Pro)</h3>
                    </div>
                        <div class="card-body">
                        <% if (user.plan === 'pro') { %>
                            <div class="form-group">
                                <label>Logo / Photo</label>
                                <input type="file" id="brandingLogoFile" class="full-input" accept="image/*">
                                <small class="field-help">Pilih file gambar langsung dari perangkat. URL tidak wajib lagi.</small>
                                <input type="hidden" id="brandingLogoUrl" value="<%= user.branding && user.branding.logoUrl ? user.branding.logoUrl : '' %>">
                                <div class="branding-preview" id="brandingPreview">
                                    <% if (user.branding && user.branding.logoUrl) { %>
                                        <img src="<%= user.branding.logoUrl %>" alt="Current branding preview">
                                    <% } else { %>
                                        <div class="branding-preview-empty"><i class="fa-solid fa-image"></i><span>No image selected</span></div>
                                    <% } %>
                                </div>
                            </div>
                            <div class="form-group">
                                <label>Primary Color</label>
                                <input type="color" id="brandingColor" class="full-input" value="<%= user.branding && user.branding.primaryColor ? user.branding.primaryColor : '#4F46E5' %>" style="padding: 5px; height: 40px;">
                            </div>
                            <div class="form-group">
                                <label>Page Title</label>
                                <input type="text" id="brandingPageTitle" class="full-input" placeholder="My Awesome Files" value="<%= user.branding && user.branding.pageTitle ? user.branding.pageTitle : '' %>">
                            </div>
                            <div class="form-actions">
                                <button id="saveBrandingBtn" class="btn primary-btn">Save Branding</button>
                            </div>
                        <% } else { %>
                            <p class="text-muted" style="text-align: center;">Upgrade to PRO to unlock custom branding for your public pages.</p>
                        <% } %>
                    </div>
                </section>

                <section class="settings-card">
                    <div class="card-header">
                        <h3><i class="fa-solid fa-key"></i> API Keys</h3>
                    </div>
                    <div class="card-body">
                        <div class="form-group" style="display:flex; gap:0.5rem;">
                            <input type="text" id="newKeyLabel" class="full-input" placeholder="Key Label (e.g. App Server)">
                            <button id="generateKeyBtn" class="btn primary-btn" style="white-space:nowrap;">Generate</button>
                        </div>
                        <p class="field-help" style="margin-top:-0.35rem;">
                            <% const apiKeyLimit = user.plan === 'pro' ? 25 : 3; %>
                            API key aktif: <strong><%= user.apiKeys ? user.apiKeys.length : 0 %></strong> / <strong><%= apiKeyLimit %></strong> untuk plan <%= user.plan.toUpperCase() %>.
                        </p>
                        
                        <div id="apiKeysList" class="items-list">
                            <% if(user.apiKeys && user.apiKeys.length > 0) { %>
                                <% user.apiKeys.forEach(apiKey => { %>
                                    <div class="list-item">
                                        <div class="item-info">
                                            <div class="item-title"><%= apiKey.label %></div>
                                            <div class="item-meta">
                                                <code id="key-<%= apiKey._id %>" data-copy-value="<%= apiKey.key %>"><%= apiKey.key %></code>
                                            </div>
                                        </div>
                                        <div class="item-actions">
                                            <button class="icon-btn" onclick="copyText('key-<%= apiKey._id %>')" title="Copy Key">
                                                <i class="fa-solid fa-copy"></i>
                                            </button>
                                            <button class="icon-btn danger" onclick="revokeApiKey('<%= apiKey._id %>')">
                                                <i class="fa-solid fa-trash"></i>
                                            </button>
                                        </div>
                                    </div>
                                <% }) %>
                            <% } else { %>
                                <p class="text-muted" style="text-align:center;">No API Keys generated.</p>
                            <% } %>
                        </div>
                    </div>
                </section>

                <section class="settings-card">
                    <div class="card-header">
                        <h3><i class="fa-solid fa-gift"></i> Referral & Storage</h3>
                    </div>
                    <div class="card-body">
                        <div class="referral-box">
                            <p>Bagikan landing page referral Anda untuk mengarahkan orang ke halaman khusus dengan username dan banner Anda.</p>
                            <div class="code-display">
                                <code id="refCode"><%= user.referralCode %></code>
                                <button class="icon-btn" onclick="copyText('refCode')"><i class="fa-solid fa-copy"></i></button>
                            </div>
                        </div>
                        <div class="referral-actions-grid">
                            <a href="/dashboard/affiliate" class="btn secondary-btn" style="justify-content:center;">
                                <i class="fa-solid fa-bullhorn"></i> Open Referral Center
                            </a>
                            <a href="/ref/<%= user.username %>" target="_blank" class="btn secondary-btn" style="justify-content:center;">
                                <i class="fa-solid fa-up-right-from-square"></i> View Referral Landing
                            </a>
                        </div>
                        <div class="referral-banner-box">
                            <img src="/ref/<%= user.username %>/banner.svg" alt="Referral banner preview">
                        </div>
                        
                        <div class="stats-row" style="margin-top:1.5rem; padding-top:1rem; border-top:1px solid var(--border);">
                            <% 
                                const totalLimit = user.storageLimit + (user.storageBonus || 0);
                                const used = user.storageUsed || 0;
                                const percentage = totalLimit > 0 ? Math.min(100, (used / totalLimit) * 100) : 0;
                                const isFull = percentage >= 90;
                            %>
                            <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:0.5rem; font-size: 0.9rem;">
                                <span class="stat-label">Storage Usage (<%= user.plan.toUpperCase() %>)</span>
                                <span class="stat-value" style="font-weight:bold; <%= isFull ? 'color:#ef4444;' : '' %>">
                                    <%= (used / 1024 / 1024).toFixed(2) %> MB / 
                                    <%= (totalLimit / 1024 / 1024 / 1024).toFixed(2) %> GB
                                </span>
                            </div>
                            <div class="progress-bar" style="height:12px; background:var(--bg-secondary); border-radius:6px; overflow:hidden; border:1px solid var(--border);">
                                <div class="fill" style="width:<%= percentage %>%; background:<%= isFull ? '#ef4444' : 'var(--primary)' %>; height:100%; transition: width 0.5s ease;"></div>
                            </div>
                            
                            <% if(user.plan === 'free') { %>
                                <a href="/billing" id="upgradeBtn" class="btn primary-btn" style="width:100%; margin-top:1rem; background: linear-gradient(45deg, #f59e0b, #d97706); border:none; text-align:center; justify-content:center;">
                                    <i class="fa-solid fa-crown"></i> Upgrade to PRO
                                </a>
                            <% } else { %>
                                <p style="margin-top:1rem; color:#16a34a; text-align:center; font-weight:500; font-size:0.9rem;">
                                    <i class="fa-solid fa-check-circle"></i> PRO Plan Active
                                </p>
                            <% } %>
                        </div>
                    </div>
                </section>

                <section class="settings-card">
                    <div class="card-header">
                        <h3><i class="fa-solid fa-shield-halved"></i> Security Center</h3>
                    </div>
                    <div class="card-body">
                        <div class="security-item">
                            <div class="security-info">
                                <strong>Two-Factor Authentication</strong>
                                <p>Secure your account with a TOTP app.</p>
                            </div>
                            <span class="badge <%= user.isTwoFactorEnabled ? 'success' : 'warning' %>">
                                <%= user.isTwoFactorEnabled ? 'Enabled' : 'Disabled' %>
                            </span>
                        </div>
                        <% if (!user.isTwoFactorEnabled) { %>
                            <button id="setup2faBtn" class="btn secondary-btn" style="width:100%">Setup 2FA</button>
                            <div id="2faSetupArea" style="display:none; margin-top:1rem; border-top:1px solid var(--border); padding-top:1rem;">
                                <p class="instruction">1. Scan QR with your authenticator app:</p>
                                <div id="qrCodeContainer" style="text-align:center; margin:1rem 0;"></div>
                                <p class="instruction">Secret: <code id="secretCode"></code></p>
                                <p class="instruction">2. Enter verification code:</p>
                                <form id="verify2faForm" style="display:flex; gap:0.5rem;">
                                    <input type="text" id="2faTokenInput" class="full-input" placeholder="000000" maxlength="6" required>
                                    <button type="submit" class="btn primary-btn">Enable</button>
                                </form>
                            </div>
                        <% } %>

                        <div class="security-item passkey-section" style="margin-top:1.5rem; padding-top:1.5rem; border-top:1px solid var(--border);">
                            <div class="security-info">
                                <strong>Passkeys (Biometric Login)</strong>
                                <p>Log in with Face ID or fingerprint.</p>
                            </div>
                            <button id="addPasskeyBtn" class="btn primary-btn"><i class="fa-solid fa-plus"></i> Add</button>
                        </div>
                        <div id="passkeyList" class="items-list">
                            <% if(user.passkeys && user.passkeys.length > 0) { %>
                                <% user.passkeys.forEach(key => { %>
                                    <div class="list-item">
                                        <div class="item-info">
                                            <span><i class="fa-solid fa-fingerprint"></i> Registered Device</span>
                                        </div>
                                        <button onclick="removePasskey('<%= key.credentialID.toString('base64url') %>')" class="btn danger-btn-sm"><i class="fa-solid fa-trash"></i></button>
                                    </div>
                                <% }) %>
                            <% } else { %>
                                <p class="text-muted" style="text-align:center; padding:1rem;">No passkeys registered.</p>
                            <% } %>
                        </div>
                    </div>
                </section>
                
                <section class="settings-card">
                    <div class="card-header">
                        <h3><i class="fa-solid fa-bolt"></i> Webhook Events</h3>
                        <button id="testWebhookBtn" class="btn secondary-btn-sm">Test Ping</button>
                    </div>
                    <div class="card-body">
                        <div class="form-group">
                            <label>Endpoint URL</label>
                            <input type="url" id="webhookUrl" class="full-input" placeholder="https://api.yourapp.com/webhook" value="<%= user.webhook ? user.webhook.url : '' %>">
                        </div>
                        <div class="form-group">
                            <label>Secret Key (Optional)</label>
                            <input type="password" id="webhookSecret" class="full-input" placeholder="Signing Secret" value="<%= user.webhook ? user.webhook.secret : '' %>">
                        </div>
                        <div class="form-row">
                            <label class="toggle-switch">
                                <input type="checkbox" id="webhookActive" <%= (user.webhook && user.webhook.isActive) ? 'checked' : '' %>>
                                <span class="slider"></span>
                                <span class="label-text">Active</span>
                            </label>
                        </div>
                        <div class="form-actions">
                            <button id="saveWebhookBtn" class="btn primary-btn">Save Configuration</button>
                        </div>
                    </div>
                </section>

                <section class="settings-card">
                    <div class="card-header">
                        <h3><i class="fa-solid fa-laptop"></i> Active Sessions</h3>
                        <button id="logoutAllBtn" class="btn danger-btn-sm">Logout Others</button>
                    </div>
                    <div class="card-body no-padding">
                        <ul class="session-list">
                            <% user.sessions.forEach(session => { %>
                                <li class="session-item">
                                    <div class="session-icon">
                                        <i class="fa-brands <%= session.os.toLowerCase().includes('win') ? 'fa-windows' : (session.os.toLowerCase().includes('mac') ? 'fa-apple' : (session.os.toLowerCase().includes('linux') ? 'fa-linux' : 'fa-mobile-screen-button')) %>"></i>
                                    </div>
                                    <div class="session-info">
                                        <div class="session-title">
                                            <%= session.os %> - <%= session.browser %>
                                            <% if(session.deviceId === currentDeviceId) { %> <span class="badge current">Current</span> <% } %>
                                        </div>
                                        <div class="session-meta">
                                            <%= session.ip %> &bull; <%= session.location || 'Unknown' %> &bull; <%= new Date(session.lastActive).toLocaleDateString() %>
                                        </div>
                                    </div>
                                    <button class="icon-btn danger" onclick="revokeSession('<%= session.deviceId %>')"><i class="fa-solid fa-trash"></i></button>
                                </li>
                            <% }) %>
                        </ul>
                    </div>
                </section>

            </div>
        </div>
    </main>
</div>

<style>
    .profile-container { padding: 1.5rem; max-width: 1200px; margin: 0 auto; }
    .profile-hero {
        display: grid;
        grid-template-columns: minmax(0, 1.45fr) minmax(280px, 0.8fr);
        gap: 1.5rem;
        padding: 1.7rem;
        border-radius: 28px;
        background:
            radial-gradient(circle at top right, rgba(249,115,22,0.18), transparent 28%),
            linear-gradient(135deg, rgba(15,23,42,0.96), rgba(37,99,235,0.9));
        color: #fff;
        margin-bottom: 1.5rem;
        border: 1px solid rgba(255,255,255,0.16);
    }
    .profile-hero-badge {
        display: inline-flex;
        padding: 0.35rem 0.72rem;
        border-radius: 999px;
        background: rgba(255,255,255,0.12);
        font-size: 0.76rem;
        font-weight: 800;
        letter-spacing: 0.05em;
        text-transform: uppercase;
    }
    .profile-hero h2 { margin: 0.85rem 0 0.75rem; font-size: clamp(1.8rem, 3vw, 2.5rem); line-height: 1.14; }
    .profile-hero p { margin: 0; color: rgba(255,255,255,0.76); line-height: 1.72; }
    .quote-bubbles { display: grid; gap: 0.85rem; margin-top: 1rem; max-width: 760px; }
    .quote-bubble {
        position: relative;
        padding: 0.95rem 1rem;
        border-radius: 20px;
        max-width: 560px;
        background: rgba(255,255,255,0.12);
        border: 1px solid rgba(255,255,255,0.16);
        box-shadow: 0 14px 30px rgba(15,23,42,0.10);
    }
    .quote-bubble p { margin: 0.15rem 0 0; color: #fff; }
    .quote-bubble.incoming { border-bottom-left-radius: 8px; }
    .quote-bubble.outgoing {
        justify-self: end;
        background: rgba(249,115,22,0.20);
        border-bottom-right-radius: 8px;
    }
    .quote-author {
        display: inline-block;
        font-size: 0.76rem;
        font-weight: 800;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.72);
        margin-bottom: 0.2rem;
    }
    .profile-hero-stats {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        margin-top: 1.35rem;
    }
    .hero-stat {
        min-width: 170px;
        padding: 0.95rem 1rem;
        border-radius: 18px;
        background: rgba(255,255,255,0.10);
        border: 1px solid rgba(255,255,255,0.14);
    }
    .hero-stat small { display: block; color: rgba(255,255,255,0.72); margin-bottom: 0.25rem; }
    .hero-stat strong { font-size: 1.25rem; }
    .profile-hero-panel {
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 0.55rem;
        padding: 1.35rem;
        border-radius: 24px;
        background: rgba(255,255,255,0.10);
        border: 1px solid rgba(255,255,255,0.16);
    }
    .hero-panel-profile {
        display: flex;
        gap: 0.9rem;
        align-items: center;
    }
    .hero-panel-profile img,
    .hero-panel-fallback {
        width: 64px;
        height: 64px;
        border-radius: 20px;
        object-fit: cover;
        border: 1px solid rgba(255,255,255,0.18);
        background: rgba(255,255,255,0.16);
    }
    .hero-panel-fallback {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 1.45rem;
        color: #fff;
    }
    .profile-hero-panel small { color: rgba(255,255,255,0.7); }
    .profile-hero-panel strong { font-size: 1.6rem; }
    .profile-hero-panel span { color: rgba(255,255,255,0.72); line-height: 1.6; }
    .settings-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); gap: 1.5rem; }
    .settings-card { background: var(--card); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; margin-bottom: 1rem; }
    .card-header { padding: 1rem 1.5rem; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; background: var(--bg-secondary); }
    .card-header h3 { font-size: 1rem; font-weight: 600; margin: 0; display: flex; align-items: center; gap: 0.5rem; }
    .card-body { padding: 1.5rem; }
    .card-body.no-padding { padding: 0; }
    .form-group { margin-bottom: 1rem; }
    .form-group label { display: block; margin-bottom: 0.5rem; font-weight: 500; font-size: 0.9rem; color: var(--muted-text); }
    .field-help { display: block; margin-top: 0.45rem; color: var(--muted-text); font-size: 0.82rem; }
    .form-actions { margin-top: 1.5rem; display: flex; gap: 1rem; justify-content: flex-end; }
    .toggle-switch { display: flex; align-items: center; cursor: pointer; gap: 0.75rem; }
    .toggle-switch input { display: none; }
    .slider { width: 40px; height: 22px; background: var(--border); border-radius: 22px; position: relative; transition: .3s; }
    .slider::before { content: ""; position: absolute; height: 16px; width: 16px; left: 3px; bottom: 3px; background: white; border-radius: 50%; transition: .3s; }
    input:checked + .slider { background: var(--primary); }
    input:checked + .slider::before { transform: translateX(18px); }
    .referral-box { background: rgba(37, 99, 235, 0.05); border: 1px dashed var(--primary); padding: 1rem; border-radius: 8px; text-align: center; }
    .referral-actions-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 0.75rem; margin-top: 1rem; }
    .referral-banner-box {
        margin-top: 1rem;
        overflow: hidden;
        border-radius: 16px;
        border: 1px solid var(--border);
        background: var(--bg-secondary);
    }
    .referral-banner-box img { width: 100%; display: block; }
    .code-display { display: flex; align-items: center; justify-content: center; gap: 1rem; margin-top: 0.5rem; font-size: 1.25rem; font-weight: bold; font-family: monospace; letter-spacing: 1px; }
    .session-list { list-style: none; padding: 0; margin: 0; }
    .session-item { display: flex; align-items: center; padding: 1rem 1.5rem; border-bottom: 1px solid var(--border); gap: 1rem; }
    .session-item:last-child { border-bottom: none; }
    .session-icon { font-size: 1.5rem; color: var(--muted-text); width: 30px; text-align: center; }
    .session-info { flex: 1; }
    .session-title { font-weight: 500; font-size: 0.95rem; }
    .session-meta { font-size: 0.8rem; color: var(--muted-text); margin-top: 0.2rem; }
    .badge { padding: 2px 8px; border-radius: 10px; font-size: 0.7rem; font-weight: 600; text-transform: uppercase; }
    .badge.success { background: #dcfce7; color: #166534; }
    .badge.warning { background: #fef9c3; color: #854d0e; }
    .badge.current { background: #dbeafe; color: #1e40af; }
    .danger-btn-sm { background: #fee2e2; color: #ef4444; border: none; padding: 0.4rem 0.8rem; border-radius: 6px; font-size: 0.8rem; cursor: pointer; }
    .secondary-btn-sm { background: var(--bg-secondary); color: var(--text); border: 1px solid var(--border); padding: 0.4rem 0.8rem; border-radius: 6px; font-size: 0.8rem; cursor: pointer; }
    .security-item { display: flex; justify-content: space-between; align-items: center; }
    .security-info p { margin: 0.25rem 0 0 0; color: var(--muted-text); font-size: 0.9rem; }
    .items-list { margin-top: 1rem; }
    .list-item { display:flex; justify-content:space-between; align-items:center; background:var(--bg-secondary); padding:0.75rem; border-radius:8px; margin-bottom:0.5rem; border:1px solid var(--border); }
    .item-info { flex: 1; overflow: hidden; }
    .item-title { font-weight: 600; font-size: 0.9rem; }
    .item-meta code { font-size: 0.8rem; background: var(--bg); border: 1px solid var(--border); padding: 2px 5px; border-radius: 4px; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 90%; margin-top: 4px; }
    .item-actions { display: flex; gap: 0.5rem; }
    .branding-preview {
        margin-top: 0.85rem;
        border-radius: 18px;
        overflow: hidden;
        border: 1px solid var(--border);
        background: var(--bg-secondary);
        min-height: 160px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .branding-preview img { width: 100%; max-height: 260px; object-fit: cover; display: block; }
    .branding-preview-empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.65rem;
        color: var(--muted-text);
        padding: 1.5rem;
    }
    @media (max-width: 900px) { .profile-hero { grid-template-columns: 1fr; } }
    @media (max-width: 768px) {
        .settings-grid { grid-template-columns: 1fr; }
        .referral-actions-grid { grid-template-columns: 1fr; }
    }
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const { startRegistration } = SimpleWebAuthnBrowser;

    const sidebar = document.getElementById('mainSidebar');
    const sidebarToggle = document.getElementById('sidebarToggle');
    const sidebarOverlay = document.getElementById('sidebarOverlay');
    const closeSidebarBtn = document.getElementById('closeSidebarBtn');

    function toggleSidebar() { 
        if(sidebar) sidebar.classList.toggle('active'); 
        if(sidebarOverlay) sidebarOverlay.classList.toggle('active'); 
    }
    
    if(sidebarToggle) sidebarToggle.addEventListener('click', toggleSidebar);
    if(closeSidebarBtn) closeSidebarBtn.addEventListener('click', toggleSidebar);
    if(sidebarOverlay) sidebarOverlay.addEventListener('click', toggleSidebar);

    window.copyText = async (elementId) => {
        const targetElement = document.getElementById(elementId);
        if (!targetElement) {
            showToast('Element to copy not found.', 'error');
            console.error(`Attempted to copy from non-existent element with ID: ${elementId}`);
            return;
        }
        const textToCopy = targetElement.innerText;
        const rawValue = targetElement.dataset?.copyValue || targetElement.textContent;
        if (!rawValue) {
            showToast('Nothing to copy.', 'warning');
            return;
        }
        try {
            await navigator.clipboard.writeText(rawValue.trim());
            showToast('Copied to clipboard!', 'success');
        } catch (err) {
            const tempInput = document.createElement('textarea');
            tempInput.value = rawValue.trim();
            tempInput.style.position = 'absolute';
            tempInput.style.left = '-9999px';
            document.body.appendChild(tempInput);
            tempInput.select();
            try {
                const success = document.execCommand('copy');
                if (success) {
                    showToast('Copied to clipboard (fallback)!', 'success');
                } else {
                    showToast('Failed to copy. Please copy manually.', 'error');
                }
            } catch (execErr) {
                showToast('Failed to copy. Please copy manually.', 'error');
            } finally {
                document.body.removeChild(tempInput);
            }
        }
    };

    let profilePhotoBase64 = <%- JSON.stringify(user.profilePhotoUrl || '') %>;
    let publicCoverBase64 = <%- JSON.stringify(user.publicCoverUrl || '') %>;

    function bindImagePreview(fileInputId, previewId, emptyIcon, emptyText, onLoad) {
        const input = document.getElementById(fileInputId);
        const preview = document.getElementById(previewId);
        if (!input || !preview) return;

        input.addEventListener('change', () => {
            const file = input.files?.[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = () => {
                preview.innerHTML = `<img src="${reader.result}" alt="Preview">`;
                if (typeof onLoad === 'function') onLoad(reader.result);
            };
            reader.readAsDataURL(file);
        });

        if (!preview.innerHTML.trim()) {
            preview.innerHTML = `<div class="branding-preview-empty"><i class="${emptyIcon}"></i><span>${emptyText}</span></div>`;
        }
    }

    bindImagePreview('profilePhotoFile', 'profilePhotoPreview', 'fa-solid fa-user-circle', 'No profile photo selected', (value) => {
        profilePhotoBase64 = value;
    });
    bindImagePreview('publicCoverFile', 'publicCoverPreview', 'fa-solid fa-panorama', 'No cover selected', (value) => {
        publicCoverBase64 = value;
    });

    const saveProfileBtn = document.getElementById('saveProfileBtn');
    if(saveProfileBtn) {
        saveProfileBtn.addEventListener('click', async () => {
            const publicBio = document.getElementById('publicBio').value;
            const isPublicProfile = document.getElementById('publicProfileToggle').checked;
            const email = document.getElementById('accountEmail').value.trim();
            const publicTitle = document.getElementById('publicTitle').value.trim();
            const publicThemeColor = document.getElementById('publicThemeColor').value;
            try {
                const res = await fetch('/api/profile/settings', {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        publicBio,
                        isPublicProfile,
                        email,
                        publicTitle,
                        publicThemeColor,
                        profilePhotoBase64,
                        publicCoverBase64
                    })
                });
                const data = await res.json();
                if(res.ok) showToast('Profile updated', 'success');
                else showToast(data.message || 'Update failed', 'error');
            } catch(e) {
                showToast('Network error', 'error');
            }
        });
    }

    const brandingLogoFile = document.getElementById('brandingLogoFile');
    const brandingLogoUrl = document.getElementById('brandingLogoUrl');
    const brandingPreview = document.getElementById('brandingPreview');

    function renderBrandingPreview(source) {
        if (!brandingPreview) return;
        if (source) {
            brandingPreview.innerHTML = `<img src="${source}" alt="Branding preview">`;
        } else {
            brandingPreview.innerHTML = '<div class="branding-preview-empty"><i class="fa-solid fa-image"></i><span>No image selected</span></div>';
        }
    }

    if (brandingLogoFile) {
        brandingLogoFile.addEventListener('change', () => {
            const file = brandingLogoFile.files?.[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = () => {
                brandingLogoUrl.value = reader.result;
                renderBrandingPreview(reader.result);
            };
            reader.readAsDataURL(file);
        });
    }

    const saveBrandingBtn = document.getElementById('saveBrandingBtn');
    if(saveBrandingBtn) {
        saveBrandingBtn.addEventListener('click', async () => {
            const logoUrl = document.getElementById('brandingLogoUrl').value;
            const primaryColor = document.getElementById('brandingColor').value;
            const pageTitle = document.getElementById('brandingPageTitle').value;
            try {
                const res = await fetch('/api/profile/branding', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        logoUrl: logoUrl && !logoUrl.startsWith('data:image/') ? logoUrl : '',
                        logoBase64: logoUrl && logoUrl.startsWith('data:image/') ? logoUrl : '',
                        primaryColor,
                        pageTitle
                    })
                });
                if(res.ok) showToast('Branding settings updated', 'success');
                else {
                    const data = await res.json();
                    showToast(data.message || 'Failed to update branding', 'error');
                }
            } catch(e) { showToast('Network error', 'error'); }
        });
    }

    const saveWebhookBtn = document.getElementById('saveWebhookBtn');
    if(saveWebhookBtn) {
        saveWebhookBtn.addEventListener('click', async () => {
            const url = document.getElementById('webhookUrl').value;
            const secret = document.getElementById('webhookSecret').value;
            const isActive = document.getElementById('webhookActive').checked;
            try {
                const res = await fetch('/api/profile/webhook', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ url, secret, isActive })
                });
                if(res.ok) showToast('Webhook configuration saved', 'success');
                else showToast('Failed to save webhook', 'error');
            } catch(e) { showToast('Network error', 'error'); }
        });
    }

    const testWebhookBtn = document.getElementById('testWebhookBtn');
    if(testWebhookBtn) {
        testWebhookBtn.addEventListener('click', async () => {
            try {
                const res = await fetch('/api/profile/webhook/test', { method: 'POST' });
                if(res.ok) showToast('Test ping sent!', 'success');
                else showToast('Failed to send test ping', 'error');
            } catch(e) { showToast('Network error', 'error'); }
        });
    }

    const generateKeyBtn = document.getElementById('generateKeyBtn');
    if(generateKeyBtn) {
        generateKeyBtn.addEventListener('click', async () => {
            const label = document.getElementById('newKeyLabel').value || 'Unnamed Key';
            generateKeyBtn.disabled = true;
            const originalContent = generateKeyBtn.innerHTML;
            generateKeyBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Creating...';
            try {
                const res = await fetch('/api/profile/api-key', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ label })
                });
                const data = await res.json();
                if(res.ok) location.reload();
                else showToast(data.message || 'Failed to generate key', 'error');
            } catch(e) { showToast('Network error', 'error'); }
            finally {
                generateKeyBtn.disabled = false;
                generateKeyBtn.innerHTML = originalContent;
            }
        });
    }

    window.revokeApiKey = async (id) => {
        if(!confirm('Revoke this API Key? Application using it will stop working.')) return;
        try {
            const res = await fetch(`/api/profile/api-key/${id}`, { method: 'DELETE' });
            if(res.ok) location.reload();
        } catch(e) { showToast('Network error', 'error'); }
    };

    const setup2faBtn = document.getElementById('setup2faBtn');
    if(setup2faBtn) {
        setup2faBtn.addEventListener('click', async () => {
            try {
                const res = await fetch('/api/profile/2fa/setup', { method: 'POST' });
                const data = await res.json();
                if(res.ok) {
                    document.getElementById('qrCodeContainer').innerHTML = `<img src="${data.qrCodeUrl}" style="max-width:150px">`;
                    document.getElementById('secretCode').textContent = data.secret;
                    document.getElementById('2faSetupArea').style.display = 'block';
                    setup2faBtn.style.display = 'none';
                }
            } catch(e) {
                showToast('Failed to setup 2FA', 'error');
            }
        });
    }

    const verify2faForm = document.getElementById('verify2faForm');
    if(verify2faForm) {
        verify2faForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const token = document.getElementById('2faTokenInput').value;
            try {
                const res = await fetch('/api/profile/2fa/verify', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ token })
                });
                if(res.ok) { 
                    showToast('2FA Enabled!', 'success'); 
                    setTimeout(() => location.reload(), 1000); 
                } else { 
                    showToast('Invalid Code', 'error'); 
                }
            } catch(e) {
                showToast('Verification failed', 'error');
            }
        });
    }

    const addPasskeyBtn = document.getElementById('addPasskeyBtn');
    if(addPasskeyBtn) {
        addPasskeyBtn.addEventListener('click', async () => {
            try {
                const resp = await fetch('/api/profile/passkey/register-options', { method: 'POST' });
                if(!resp.ok) throw new Error('Failed to get options');
                
                const options = await resp.json();
                const attResp = await startRegistration(options);
                
                const verificationResp = await fetch('/api/profile/passkey/verify-registration', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(attResp),
                });
                
                const verificationJSON = await verificationResp.json();
                if (verificationJSON && verificationJSON.verified) {
                    showToast('Passkey registered successfully!', 'success');
                    setTimeout(() => location.reload(), 1000);
                } else {
                    showToast('Registration failed', 'error');
                }
            } catch (error) {
                showToast('Could not create passkey: ' + error.message, 'error');
            }
        });
    }

    window.removePasskey = async (id) => {
        if (!confirm('Remove this passkey?')) return;
        try {
            const res = await fetch(`/api/profile/passkey/${id}`, { method: 'DELETE' });
            if (res.ok) {
                showToast('Passkey removed.', 'success');
                setTimeout(() => location.reload(), 1000);
            } else {
                showToast('Failed to remove passkey.', 'error');
            }
        } catch(e) {
            showToast('Network error', 'error');
        }
    };

    window.revokeSession = async (deviceId) => {
        if(!confirm('Log out this device?')) return;
        try {
            const res = await fetch(`/api/profile/devices/${deviceId}`, { method: 'DELETE' });
            if(res.ok) location.reload();
        } catch(e) {}
    };

    const logoutAllBtn = document.getElementById('logoutAllBtn');
    if(logoutAllBtn) {
        logoutAllBtn.addEventListener('click', async () => {
            if(!confirm('Log out all OTHER devices?')) return;
            try {
                const res = await fetch('/api/profile/devices', { method: 'DELETE' });
                if(res.ok) location.reload();
            } catch(e) {}
        });
    }
});
</script>

<%- include('partials/footer') %>
