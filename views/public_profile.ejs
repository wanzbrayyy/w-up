<%- include('partials/header', { title: publicDisplayTitle, pageCss: 'dashboard' }) %>

<style>
    :root {
        --branded-primary: <%= targetUser.branding?.primaryColor || targetUser.publicThemeColor || '#2563eb' %>;
    }
    .public-profile-shell {
        max-width: 1240px;
        margin: 0 auto;
        padding: 1.5rem 1.25rem 3rem;
    }
    .public-profile-hero {
        position: relative;
        overflow: hidden;
        display: grid;
        grid-template-columns: minmax(0, 1.4fr) minmax(320px, 0.8fr);
        gap: 1.5rem;
        padding: 1.8rem;
        border-radius: 30px;
        color: #fff;
        border: 1px solid rgba(255,255,255,0.16);
        box-shadow: 0 30px 60px rgba(15, 23, 42, 0.18);
        background:
            radial-gradient(circle at top right, rgba(249,115,22,0.16), transparent 24%),
            linear-gradient(135deg, rgba(15,23,42,0.96), var(--branded-primary));
    }
    .hero-cover {
        position: absolute;
        inset: 0;
        opacity: 0.22;
        pointer-events: none;
    }
    .hero-cover img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }
    .hero-cover canvas {
        width: 100%;
        height: 100%;
        display: block;
    }
    .hero-content,
    .hero-side {
        position: relative;
        z-index: 1;
    }
    .profile-identity {
        display: flex;
        gap: 1rem;
        align-items: center;
        margin-bottom: 1rem;
    }
    .profile-avatar {
        width: 86px;
        height: 86px;
        border-radius: 24px;
        background: rgba(255,255,255,0.14);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        border: 1px solid rgba(255,255,255,0.18);
        overflow: hidden;
        box-shadow: 0 18px 36px rgba(15,23,42,0.18);
    }
    .profile-avatar img { width: 100%; height: 100%; object-fit: cover; }
    .public-status {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.35rem 0.7rem;
        border-radius: 999px;
        background: rgba(255,255,255,0.14);
        font-size: 0.78rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        margin-bottom: 0.35rem;
    }
    .profile-hero-copy h1 { margin: 0; font-size: clamp(2rem, 3vw, 2.9rem); line-height: 1.08; }
    .profile-hero-copy p { margin: 0.75rem 0 0; color: rgba(255,255,255,0.78); line-height: 1.78; max-width: 720px; }
    .hero-stats {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1rem;
        margin-top: 1.4rem;
    }
    .hero-stat {
        padding: 1rem;
        border-radius: 20px;
        background: rgba(255,255,255,0.10);
        border: 1px solid rgba(255,255,255,0.16);
    }
    .hero-stat small { display: block; color: rgba(255,255,255,0.7); margin-bottom: 0.3rem; }
    .hero-stat strong { font-size: 1.22rem; }
    .hero-side-card {
        background: rgba(255,255,255,0.10);
        border: 1px solid rgba(255,255,255,0.16);
        border-radius: 24px;
        padding: 1.3rem;
        backdrop-filter: blur(10px);
    }
    .hero-side-card h3 { margin-top: 0; margin-bottom: 0.45rem; }
    .hero-side-card p { margin: 0 0 1rem; color: rgba(255,255,255,0.76); line-height: 1.7; }
    .upload-area {
        border: 1.5px dashed rgba(255,255,255,0.24);
        border-radius: 20px;
        padding: 2rem 1.15rem;
        text-align: center;
        cursor: pointer;
        transition: transform 0.2s ease, background 0.2s ease, border-color 0.2s ease;
        background: rgba(255,255,255,0.06);
    }
    .upload-area:hover, .upload-area.drag-over {
        transform: translateY(-2px);
        background: rgba(255,255,255,0.1);
        border-color: rgba(255,255,255,0.42);
    }
    .upload-list {
        margin-top: 1rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }
    .public-section-head {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: flex-end;
        margin: 2rem 0 1rem;
    }
    .public-section-head h2 { margin: 0; }
    .public-section-head p { margin: 0.35rem 0 0; color: var(--muted-text); }
    .public-file-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 1rem;
    }
    .public-file-card {
        border-radius: 22px;
        background: var(--card);
        border: 1px solid var(--border);
        overflow: hidden;
        box-shadow: 0 18px 36px rgba(15, 23, 42, 0.06);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .public-file-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 24px 44px rgba(15, 23, 42, 0.10);
    }
    .public-file-preview {
        min-height: 170px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, rgba(37,99,235,0.10), rgba(249,115,22,0.10));
        color: var(--branded-primary);
        font-size: 2rem;
    }
    .public-file-preview img {
        width: 100%;
        height: 170px;
        object-fit: cover;
        display: block;
    }
    .public-file-body { padding: 1rem; }
    .public-file-body a { display: block; font-weight: 700; color: var(--text); text-decoration: none; }
    .public-file-body small { display: block; margin-top: 0.5rem; color: var(--muted-text); }
    @media (max-width: 980px) {
        .public-profile-hero { grid-template-columns: 1fr; }
    }
    @media (max-width: 700px) {
        .hero-stats { grid-template-columns: 1fr; }
        .public-section-head { flex-direction: column; align-items: flex-start; }
    }
</style>

<main class="public-profile-shell">
    <section class="public-profile-hero">
        <div class="hero-cover">
            <% if (targetUser.publicCoverUrl) { %>
                <img src="<%= targetUser.publicCoverUrl %>" alt="Public cover">
            <% } else { %>
                <canvas id="profileHeroCanvas" width="1280" height="720"></canvas>
            <% } %>
        </div>

        <div class="hero-content profile-hero-copy">
            <div class="profile-identity">
                <div class="profile-avatar">
                    <% if (targetUser.profilePhotoUrl) { %>
                        <img src="<%= targetUser.profilePhotoUrl %>" alt="Profile photo">
                    <% } else if (targetUser.branding?.logoUrl) { %>
                        <img src="<%= targetUser.branding.logoUrl %>" alt="Profile logo">
                    <% } else { %>
                        <i class="fa-solid fa-user-astronaut"></i>
                    <% } %>
                </div>
                <div>
                    <span class="public-status">
                        <i class="fa-solid fa-circle-check"></i> Public Page Active
                    </span>
                    <h1><%= publicDisplayTitle %></h1>
                </div>
            </div>
            <p><%= targetUser.publicBio || 'Halaman publik ini dipakai untuk menerima upload dan menampilkan file yang dibagikan oleh pengguna.' %></p>

            <div class="hero-stats">
                <div class="hero-stat">
                    <small>Total file publik</small>
                    <strong><%= publicStats.totalFiles %></strong>
                </div>
                <div class="hero-stat">
                    <small>Total download</small>
                    <strong><%= publicStats.totalDownloads %></strong>
                </div>
                <div class="hero-stat">
                    <small>Total size</small>
                    <strong><%= (publicStats.totalSize / 1024 / 1024).toFixed(1) %> MB</strong>
                </div>
            </div>
        </div>

        <div class="hero-side">
            <div class="hero-side-card">
                <h3>Kirim file ke <%= targetUser.username %></h3>
                <p>Upload langsung dari public page ini untuk revisi, submission, bahan desain, atau file dari klien.</p>

                <div class="upload-area" id="dropZone">
                    <input type="file" id="fileInput" multiple hidden>
                    <div class="upload-placeholder">
                        <i class="fa-solid fa-cloud-arrow-up" style="font-size: 2rem; margin-bottom: 0.75rem;"></i>
                        <p style="margin:0;"><strong>Upload file</strong> atau drag & drop di sini</p>
                    </div>
                </div>

                <div id="uploadList" class="upload-list"></div>
            </div>
        </div>
    </section>

    <div class="public-section-head">
        <div>
            <h2>Galeri file publik</h2>
            <p>Koleksi file yang dibagikan di halaman ini.</p>
        </div>
    </div>

    <section class="public-file-grid">
        <% if (files.length === 0) { %>
            <div class="empty-state" style="grid-column: 1 / -1;">
                <i class="fa-solid fa-box-open"></i>
                <p>Belum ada file publik yang dibagikan.</p>
            </div>
        <% } %>

        <% files.forEach(file => { 
            const ext = file.originalName.split('.').pop().toLowerCase();
        %>
            <article class="public-file-card">
                <div class="public-file-preview">
                    <% if (file.contentType.startsWith('image/')) { %>
                        <img src="/w-upload/raw/<%= file.customAlias %>" alt="<%= file.originalName %>">
                    <% } else if (file.contentType.startsWith('video/')) { %>
                        <i class="fa-solid fa-video"></i>
                    <% } else if (ext === 'pdf') { %>
                        <i class="fa-solid fa-file-pdf"></i>
                    <% } else if (ext === 'zip' || ext === 'rar') { %>
                        <i class="fa-solid fa-file-zipper"></i>
                    <% } else { %>
                        <i class="fa-solid fa-file-lines"></i>
                    <% } %>
                </div>
                <div class="public-file-body">
                    <a href="/w-upload/file/<%= file.customAlias %>"><%= file.originalName %></a>
                    <small><%= (file.size / 1024 / 1024).toFixed(2) %> MB | <%= file.downloads || 0 %> download</small>
                </div>
            </article>
        <% }) %>
    </section>
</main>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const dropZone = document.getElementById('dropZone');
    const fileInput = document.getElementById('fileInput');
    const uploadList = document.getElementById('uploadList');
    const publicUsername = "<%= targetUser.username %>";
    const heroCanvas = document.getElementById('profileHeroCanvas');

    if (heroCanvas) {
        const ctx = heroCanvas.getContext('2d');
        const width = heroCanvas.width;
        const height = heroCanvas.height;
        const primary = '<%= targetUser.branding?.primaryColor || targetUser.publicThemeColor || "#2563eb" %>';

        const gradient = ctx.createLinearGradient(0, 0, width, height);
        gradient.addColorStop(0, '#0f172a');
        gradient.addColorStop(0.6, primary);
        gradient.addColorStop(1, '#f97316');
        ctx.fillStyle = gradient;
        ctx.fillRect(0, 0, width, height);

        ctx.globalAlpha = 0.14;
        ctx.fillStyle = '#ffffff';
        ctx.beginPath();
        ctx.arc(width - 180, 130, 140, 0, Math.PI * 2);
        ctx.fill();
        ctx.beginPath();
        ctx.arc(150, height - 80, 210, 0, Math.PI * 2);
        ctx.fill();

        ctx.globalAlpha = 1;
        ctx.strokeStyle = 'rgba(255,255,255,0.14)';
        for (let i = 0; i < 5; i++) {
            ctx.beginPath();
            ctx.roundRect(80 + i * 55, 90 + i * 26, 220, 62, 22);
            ctx.stroke();
        }
    }

    dropZone.addEventListener('click', () => fileInput.click());
    dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('drag-over'); });
    dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
    dropZone.addEventListener('drop', e => { e.preventDefault(); dropZone.classList.remove('drag-over'); handleFiles(e.dataTransfer.files); });
    fileInput.addEventListener('change', e => { handleFiles(e.target.files); fileInput.value = ''; });

    function handleFiles(files) {
        Array.from(files).forEach(uploadFile);
    }

    function createUploadItem(file) {
        const item = document.createElement('div');
        item.style = 'display:flex;align-items:center;gap:1rem;padding:0.9rem 1rem;background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.14);border-radius:16px;text-align:left;color:#fff;';
        item.innerHTML = `<i class="fa-solid fa-spinner fa-spin"></i><div style="flex:1;min-width:0;"><div style="font-size:0.92rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${file.name}</div><div class="status" style="font-size:0.82rem;color:rgba(255,255,255,0.7);">Uploading...</div></div>`;
        uploadList.prepend(item);
        return item;
    }

    function updateItemStatus(item, status, message) {
        const icon = item.querySelector('i');
        const statusText = item.querySelector('.status');
        if (status === 'success') {
            icon.className = 'fa-solid fa-check-circle';
            icon.style.color = '#86efac';
            statusText.textContent = 'Uploaded successfully';
        } else {
            icon.className = 'fa-solid fa-circle-exclamation';
            icon.style.color = '#fecaca';
            statusText.textContent = message || 'Upload failed';
        }
    }

    function uploadFile(file) {
        const item = createUploadItem(file);
        const reader = new FileReader();
        reader.onload = async () => {
            try {
                const res = await fetch('/api/upload', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        filename: file.name,
                        contentType: file.type || 'application/octet-stream',
                        base64: reader.result,
                        publicProfileUsername: publicUsername
                    })
                });
                const data = await res.json();
                if (res.ok) {
                    updateItemStatus(item, 'success');
                    showToast('File uploaded to public profile.', 'success');
                } else {
                    updateItemStatus(item, 'error', data.message);
                }
            } catch (error) {
                updateItemStatus(item, 'error', 'Network error');
            }
        };
        reader.readAsDataURL(file);
    }
});
</script>

<%- include('partials/footer') %>
